---
import "../styles/global.css";
import { sitePath } from "../utils/paths";

type Props = {
  title?: string;
  description?: string;
  bodyClass?: string;
  canonicalPath?: string;
  ogType?: "website" | "article";
};

const {
  title = "Readingo - Apprendre à lire en jouant",
  description = "Des mini-jeux gratuits pour aider les enfants de 5 à 7 ans à apprendre les lettres, les syllabes et les mots.",
  bodyClass = "",
  canonicalPath,
  ogType = "website",
} = Astro.props;

const canonicalUrl = canonicalPath
  ? new URL(sitePath(canonicalPath), Astro.site ?? Astro.url).toString()
  : undefined;

---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={ogType} />
    {canonicalUrl && <meta property="og:url" content={canonicalUrl} />}
    {canonicalUrl && <link rel="canonical" href={canonicalUrl} />}
    <link rel="icon" href={sitePath("/favicon.svg")} type="image/svg+xml" />
    <link
      rel="preload"
      href={sitePath("/assets/fonts/nunito-latin.ttf")}
      as="font"
      type="font/ttf"
      crossorigin="anonymous"
    />
    <style
      is:inline
      set:html={`@font-face{font-family:Nunito;src:url("${sitePath("/assets/fonts/nunito-latin.ttf")}") format("truetype");font-style:normal;font-weight:200 1000;font-display:swap;}`}
    ></style>
    <title>{title}</title>
    <slot name="head" />
  </head>
  <body class={bodyClass}>
    <header class="site-header">
      <div class="site-header__inner page-shell">
        <a class="brand" href={sitePath("/")} aria-label="Accueil Readingo">
          <span class="brand__mark" aria-hidden="true">
            <span class="brand__sail"></span>
          </span>
          <span class="brand__name">Readingo</span>
        </a>
        <nav class="main-nav" aria-label="Navigation principale">
          <a href={sitePath("/#jeux")}>Jeux</a>
          <a class="main-nav__link--secondary" href={sitePath("/#parents")}>Pour les parents</a>
          <a class="main-nav__link--secondary" href={sitePath("/apprendre-a-lire/")}>Conseils</a>
          <a class="main-nav__cta" href={sitePath("/#jeux")}>Jouer</a>
        </nav>
      </div>
    </header>
    <slot />
    <footer class="site-footer">
      <div class="site-footer__inner page-shell">
        <div class="site-footer__brand">
          <strong>Readingo</strong>
          <span>Apprendre à lire devient une aventure.</span>
        </div>
        <nav class="site-footer__nav" aria-label="Navigation de pied de page">
          <a href={sitePath("/#jeux")}>Jeux</a>
          <a href={sitePath("/apprendre-a-lire/")}>Conseils pour les parents</a>
        </nav>
      </div>
    </footer>
  </body>
</html>
