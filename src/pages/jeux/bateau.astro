---
import BaseLayout from "@layouts/BaseLayout.astro";
import { BateauGame } from "@components/games/BateauGame";
---

<BaseLayout
  bodyClass="game-layout"
  title="Jeu Bateau - Composer des mots avec des syllabes"
  description="Un mini-jeu Readingo pour apprendre a construire des mots simples a partir de syllabes."
>
  <main class="game-page">
    <div class="game-page__header page-shell">
      <p>Maîtriser les syllabes</p>
      <h1>L'Archipel des mots</h1>
      <span>Aide Pana la pirate à trouver des trésors en composant des mots</span>
    </div>
    <div class="game-page__frame page-shell">
      <BateauGame client:load />
    </div>
  </main>
</BaseLayout>

<style>
  .game-page {
    padding-block: 32px 48px;
  }

  .game-page__header {
    display: grid;
    gap: 8px;
    margin-bottom: 24px;
  }

  .game-page__header p {
    margin: 0;
    color: var(--color-blue-dark);
    font-weight: 950;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .game-page__header h1 {
    margin: 0;
    font-size: clamp(3rem, 8vw, 6rem);
    line-height: 1;
  }

  .game-page__header span {
    color: var(--color-muted);
    font-weight: 800;
  }

  .game-page__frame {
    max-width: 880px;
  }

  @media (max-width: 700px) {
    .game-page {
      height: calc(100vh - 65px);
      height: calc(100dvh - 65px);
      padding: 0;
    }

    .game-page__header {
      display: none;
    }

    .game-page__frame {
      width: 100%;
      height: 100%;
    }

    :global(.game-layout .site-footer) {
      display: none;
    }
  }
</style>
