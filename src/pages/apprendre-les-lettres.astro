---
import GuideLayout from "@layouts/GuideLayout.astro";
import { sitePath } from "../utils/paths";

const faqEntries = [
  {
    question: "Dans quel ordre apprendre les lettres ?",
    answer:
      "Commencez par les lettres qui ont du sens pour l’enfant, notamment celles de son prénom et des prénoms familiers. Ajoutez ensuite quelques lettres très différentes par leur forme et leur son. L’alphabet complet se construit progressivement, avec des retours fréquents.",
  },
  {
    question: "Faut-il apprendre le nom ou le son des lettres ?",
    answer:
      "Les deux connaissances sont utiles. Le nom permet de désigner la lettre et de l’épeler. Le son aide à comprendre comment elle participe à l’écriture des mots. Vous pouvez dire simplement : voici la lettre F, elle fait souvent /f/.",
  },
  {
    question: "Mon enfant doit-il connaître tout l’alphabet avant le CP ?",
    answer:
      "Le programme vise une connaissance progressive des lettres en fin de grande section. Les acquis peuvent rester inégaux. L’école observe aussi la capacité à reconnaître les graphies, à écouter les sons et à utiliser les lettres dans de premiers essais d’écriture.",
  },
  {
    question: "Pourquoi apprendre les capitales, le script et la cursive ?",
    answer:
      "Une même lettre apparaît sous plusieurs formes. Les capitales sont fréquentes dans les premiers repères de classe. Le script minuscule domine dans les livres. La cursive sert à écrire à la main. Relier ces graphies aide l’enfant à reconnaître une lettre partout.",
  },
  {
    question: "Les confusions entre b, d, p et q sont-elles inquiétantes ?",
    answer:
      "Des confusions ponctuelles peuvent accompagner la découverte des lettres proches. Faites observer le sens du tracé et utilisez des mots repères. Si elles restent nombreuses malgré les reprises ou s’ajoutent à d’autres difficultés, partagez vos observations avec l’enseignant.",
  },
  {
    question: "Combien de temps pratiquer à la maison ?",
    answer:
      "Cinq à dix minutes suffisent pour une activité ciblée. Arrêtez lorsque l’attention baisse. Une lettre retrouvée dans un prénom, un livre ou une enseigne au cours de la journée compte aussi comme une occasion d’apprendre.",
  },
];

const toc = [
  { href: "#comprendre", label: "Nom, forme et son" },
  { href: "#avant-4-ans", label: "Avant 4 ans" },
  { href: "#a-partir-4-ans", label: "À partir de 4 ans" },
  { href: "#a-partir-5-ans", label: "À partir de 5 ans" },
  { href: "#trois-graphies", label: "Les trois graphies" },
  { href: "#jeux-maison", label: "Jeux à la maison" },
  { href: "#difficultes", label: "Repérer les difficultés" },
  { href: "#faq", label: "Questions fréquentes" },
];

const sources = [
  {
    href: "https://www.education.gouv.fr/bo/2024/Hebdo41/MENE2415135A",
    label: "Bulletin officiel, programme de langage oral et écrit du cycle 1",
  },
  {
    href: "https://eduscol.education.fr/4698/le-developpement-et-la-structuration-du-langage-oral-et-ecrit-au-cycle-1",
    label: "Éduscol, ressources d’accompagnement du programme de cycle 1",
  },
  {
    href: "https://eduscol.education.fr/document/301/download?attachment=",
    label: "Éduscol, préparer l’apprentissage de la lecture et de l’écriture à la maternelle",
  },
];

const relatedGuides = [
  {
    href: "/apprendre-les-syllabes/",
    title: "Apprendre les syllabes",
    description: "Passer de l’écoute des mots à la manipulation des syllabes.",
  },
  {
    href: "/conscience-phonologique-maternelle/",
    title: "La conscience phonologique",
    description: "Comprendre comment l’enfant découvre les sons de la langue.",
  },
