---
import GuideLayout from "@layouts/GuideLayout.astro";
import { sitePath } from "../utils/paths";

const faqEntries = [
  {
    question: "Qu’est-ce que la conscience phonologique ?",
    answer:
      "C’est la capacité à écouter volontairement les unités sonores de la langue et à agir dessus. L’enfant apprend à repérer les mots, les syllabes, les rimes puis certains phonèmes. Il peut les compter, les comparer, les retirer ou les combiner.",
  },
  {
    question: "La phonologie sert-elle à mieux prononcer ?",
    answer:
      "La phonologie développe surtout l’attention portée aux sons de la langue. La prononciation et l’articulation participent à cette écoute, mais elles correspondent à des compétences différentes. Un enfant peut réussir un jeu de rimes tout en prononçant encore certains sons avec difficulté.",
  },
  {
    question: "Quelle différence entre une syllabe et un phonème ?",
    answer:
      "La syllabe forme un morceau de mot facilement rythmé, comme BA et TEAU dans BATEAU. Le phonème est une unité plus petite, comme /f/ dans FÉE. Les enfants manipulent généralement les syllabes avant d’isoler les phonèmes.",
  },
  {
    question: "Combien de temps doit durer un jeu phonologique ?",
    answer:
      "Une activité de cinq minutes peut suffire. Choisissez un seul objectif, comme trouver une rime ou frapper trois mots. Arrêtez pendant que l’enfant reste disponible et reprenez régulièrement avec de nouveaux exemples.",
  },
  {
    question: "Peut-on jouer avec les sons dans plusieurs langues ?",
    answer:
      "Oui. Les comptines, les rimes et les jeux d’écoute peuvent vivre dans toutes les langues de la famille. Comparez les sonorités avec curiosité. Lorsque des difficultés sont observées, indiquez aux enseignants et aux professionnels les langues comprises et parlées par l’enfant.",
  },
  {
    question: "Quand parler des difficultés avec l’enseignant ?",
    answer:
      "Échangez avec l’enseignant lorsque l’enfant peine durablement à écouter une courte consigne sonore, mémoriser une comptine, scander des mots familiers ou repérer des ressemblances malgré des activités répétées. Les observations croisées permettent de choisir la suite adaptée.",
  },
];

const toc = [
  { href: "#definition", label: "Définition simple" },
  { href: "#unites", label: "Mots, syllabes et phonèmes" },
  { href: "#importance", label: "Pourquoi la travailler" },
  { href: "#progression-age", label: "La progression par âge" },
  { href: "#activites", label: "Jeux à la maison" },
  { href: "#observer", label: "Observer les progrès" },
  { href: "#difficultes", label: "En cas de difficultés" },
  { href: "#faq", label: "Questions fréquentes" },
];

const sources = [
  {
    href: "https://www.education.gouv.fr/bo/2024/Hebdo41/MENE2415135A",
    label: "Bulletin officiel, programme de langage oral et écrit du cycle 1",
  },
  {
    href: "https://eduscol.education.fr/document/13870/download",
    label: "Éduscol, guide de référence sur la conscience phonologique",
  },
  {
    href: "https://eduscol.education.fr/document/301/download?attachment=",
    label: "Éduscol, préparer l’apprentissage de la lecture et de l’écriture à la maternelle",
  },
];

const relatedGuides = [
  {
    href: "/apprendre-les-syllabes/",
    title: "Apprendre les syllabes",
    description: "Des gestes et des jeux pour entendre les morceaux des mots.",
  },
  {
    href: "/apprendre-les-lettres/",
    title: "Apprendre les lettres",
    description: "Relier les sons entendus aux lettres qui les représentent.",
