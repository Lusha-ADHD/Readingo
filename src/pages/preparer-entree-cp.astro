---
import GuideLayout from "@layouts/GuideLayout.astro";
import GameCard from "@components/ui/GameCard.astro";

const faqEntries = [
  {
    question: "Faut-il savoir lire avant d’entrer au CP ?",
    answer:
      "Non. L’apprentissage systématique de la lecture est conduit au CP. La maternelle prépare l’enfant grâce au langage oral, aux histoires, aux syllabes, aux sons, aux lettres et aux premiers essais d’écriture. Une attitude curieuse et confiante constitue déjà un appui précieux.",
  },
  {
    question: "Un cahier de vacances est-il nécessaire ?",
    answer:
      "Il peut servir si l’enfant aime ce support, mais il ne constitue pas une obligation. Les lectures, les jeux de sons, le dessin, les lettres mobiles, les recettes et les activités quotidiennes offrent de nombreuses occasions de mobiliser les mêmes compétences.",
  },
  {
    question: "Doit-on faire travailler l’écriture cursive pendant l’été ?",
    answer:
      "Vous pouvez proposer le prénom et quelques mots déjà travaillés en classe, avec un modèle adapté. Gardez des temps courts et une posture confortable. Le dessin, le découpage et la pâte à modeler entretiennent aussi la motricité fine utile à l’écriture.",
  },
  {
    question: "À quelle fréquence proposer des activités ?",
    answer:
      "Deux ou trois courts rendez-vous par semaine suffisent, en plus des histoires partagées. Variez les activités et laissez des journées entièrement libres. Une routine prévisible aide l’enfant à participer sans transformer les vacances en temps scolaire.",
  },
  {
    question: "Quelle place donner aux écrans éducatifs ?",
    answer:
      "Utilisez-les comme un complément ponctuel. Une partie de 5 à 10 minutes, accompagnée par un adulte, permet de parler des lettres, des syllabes ou des mots rencontrés. Prolongez ensuite avec un livre, un dessin ou une activité de manipulation.",
  },
  {
    question: "Que faire si des difficultés sont repérées avant la rentrée ?",
    answer:
      "Reprenez les observations transmises par l’enseignant de grande section et notez les situations difficiles à la maison. Rassurez l’enfant et évitez les comparaisons. Contactez l’école ou le professionnel déjà impliqué si un suivi est prévu. Pour une difficulté persistante de langage, d’audition ou de vision, demandez conseil au médecin.",
  },
];

const toc = [
  { href: "#priorites", label: "Ce qui compte avant le CP" },
  { href: "#competences", label: "Les compétences utiles" },
  { href: "#rythme", label: "Un rythme hebdomadaire" },
  { href: "#vacances", label: "Une routine pour les vacances" },
  { href: "#jeux", label: "Les mini-jeux adaptés" },
  { href: "#autonomie", label: "Autonomie et premiers jours" },
  { href: "#difficultes", label: "En cas de difficultés" },
  { href: "#faq", label: "Questions fréquentes" },
];

const sources = [
  {
    href: "https://www.education.gouv.fr/bo/2024/Hebdo41/MENE2415135A",
    label: "Bulletin officiel, programmes de langage du cycle 1 et de français du cycle 2",
  },
  {
    href: "https://eduscol.education.fr/4740/ressources-d-accompagnement-du-programme-de-francais-au-cycle-2",
    label: "Éduscol, ressources d’accompagnement du programme de français au cycle 2",
  },
  {
    href: "https://www.education.gouv.fr/votre-enfant-au-cp-des-reperes-pour-l-accompagner-tout-au-long-de-l-annee-453744",
    label: "Ministère de l’Éducation nationale, repères pour accompagner un enfant au CP",
  },
];

const relatedGuides = [
  {
    href: "/apprendre-a-lire/",
    title: "Les bases de la lecture",
    description: "Revoir la progression complète suivie pendant la maternelle.",
  },
  {
    href: "/apprendre-les-lettres/",
    title: "Apprendre les lettres",
    description: "Consolider les graphies, les noms et les sons avant le CP.",
  },
