---
import { sitePath } from "../../utils/paths";

type Props = {
  title: string;
  description: string;
  href: string;
  variant?: "blue" | "green" | "gold" | "purple";
};

const { title, description, href, variant = "blue" } = Astro.props;
---

<a class={`game-card game-card--${variant}`} href={sitePath(href)}>
  <span class="game-card__icon" aria-hidden="true">{title.slice(0, 1)}</span>
  <span class="game-card__content">
    <strong>{title}</strong>
    <span>{description}</span>
  </span>
  <span class="game-card__arrow" aria-hidden="true"><span class="game-card__arrow-glyph">&gt;</span></span>
</a>

<style>
  .game-card {
    display: grid;
    grid-template-columns: 76px 1fr 48px;
    min-height: 132px;
    align-items: center;
    gap: 18px;
    padding: 18px;
    border: 3px solid var(--color-border);
    border-radius: 22px;
    background: #ffffff;
    box-shadow: 0 8px 0 rgba(8, 33, 74, 0.12);
  }

  .game-card__icon,
  .game-card__arrow {
    display: grid;
    place-items: center;
    border: 3px solid var(--color-border);
    font-weight: 950;
  }

  .game-card__icon {
    width: 76px;
    height: 76px;
    border-radius: 18px;
    color: #ffffff;
    font-size: 2.8rem;
    line-height: 1;
  }

  .game-card__arrow {
    position: relative;
    width: 48px;
    height: 48px;
    border-radius: 16px;
    color: #ffffff;
  }

  .game-card__arrow-glyph {
    position: absolute;
    top: 50%;
    left: 50%;
    color: #ffffff;
    font-family: Arial, sans-serif;
    font-size: 2rem;
    font-weight: 900;
    line-height: 1;
    transform: translate(-50%, -54%);
  }

  .game-card__content {
    display: grid;
    gap: 4px;
    min-width: 0;
  }

  .game-card strong {
    font-size: clamp(1.6rem, 3vw, 2rem);
    line-height: 1.1;
  }

  .game-card__content > span {
    color: var(--color-muted);
    font-weight: 750;
  }

  .game-card--blue .game-card__icon,
  .game-card--blue .game-card__arrow {
    background: var(--color-blue);
  }

  .game-card--green .game-card__icon,
  .game-card--green .game-card__arrow {
    background: var(--color-green);
  }

  .game-card--gold .game-card__icon,
  .game-card--gold .game-card__arrow {
    background: var(--color-gold);
    color: var(--color-text);
  }

  .game-card--gold .game-card__arrow-glyph {
    color: var(--color-text);
  }

  .game-card--purple .game-card__icon,
  .game-card--purple .game-card__arrow {
    background: var(--color-purple);
  }

  @media (max-width: 620px) {
    .game-card {
      grid-template-columns: 62px 1fr 42px;
      min-height: 106px;
      gap: 12px;
      padding: 14px;
    }

    .game-card__icon {
      width: 62px;
      height: 62px;
      font-size: 2.1rem;
    }

    .game-card__arrow {
      width: 42px;
      height: 42px;
    }
  }
</style>
