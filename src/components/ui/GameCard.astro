---
import { sitePath } from "../../utils/paths";

type Props = {
  title: string;
  description: string;
  href?: string;
  icon?: string;
  meta?: string;
  cta?: string;
  status?: string;
  progressKey?: string;
  theme?: "letters" | "bateau" | "forest";
  variant?: "blue" | "green" | "gold" | "purple";
};

const {
  title,
  description,
  href,
  icon = title.slice(0, 1),
  meta,
  cta = "Jouer",
  status,
  progressKey,
  theme,
  variant = "blue",
} = Astro.props;
const Tag = href ? "a" : "article";
const resolvedTheme =
  theme ??
  (variant === "green" || variant === "gold"
    ? "bateau"
    : variant === "purple"
      ? "forest"
      : "letters");
---

<Tag
  class={`game-card game-card--${resolvedTheme} ${href ? "game-card--interactive" : "game-card--upcoming"}`}
  href={href ? sitePath(href) : undefined}
  data-progress-key={progressKey}
>
  <span class="game-card__visual" aria-hidden="true">
    {resolvedTheme === "letters" && (
      <>
        <span class="game-card__planet">
          <span class="game-card__planet-ring game-card__planet-ring--back"></span>
          <span class="game-card__planet-body"></span>
          <span class="game-card__planet-ring game-card__planet-ring--front"></span>
        </span>
        <svg class="game-card__constellation" viewBox="0 0 240 120">
          <path d="M15 92 58 42 104 73 149 24 218 65"></path>
          <circle cx="15" cy="92" r="5"></circle>
          <circle cx="58" cy="42" r="5"></circle>
          <circle cx="104" cy="73" r="5"></circle>
          <circle cx="149" cy="24" r="5"></circle>
          <circle cx="218" cy="65" r="5"></circle>
        </svg>
        <span class="game-card__shooting-star"></span>
      </>
    )}

    {resolvedTheme === "bateau" && (
      <>
        <span class="game-card__sun"></span>
        <span class="game-card__ocean game-card__ocean--back"></span>
        <span class="game-card__ocean game-card__ocean--front"></span>
        <img
          class="game-card__island game-card__island--far"
          src={sitePath("/assets/world/map-island-rocky.png")}
          alt=""
          loading="lazy"
          width="768"
          height="768"
        />
        <img
          class="game-card__island game-card__island--near"
          src={sitePath("/assets/world/IslandWithoutChest.png")}
          alt=""
          loading="lazy"
          width="494"
          height="494"
        />
        <span class="game-card__wind game-card__wind--one"></span>
        <span class="game-card__wind game-card__wind--two"></span>
        <span class="game-card__wind game-card__wind--three"></span>
        <img
          class="game-card__boat"
          src={sitePath("/assets/world/boat.png")}
          alt=""
          loading="lazy"
          width="508"
          height="508"
        />
      </>
    )}

    {resolvedTheme === "forest" && (
      <>
        <img
          class="game-card__jungle-backdrop"
          src={sitePath("/assets/world/jungle/jungle-backdrop.png")}
          alt=""
          loading="lazy"
          width="1672"
          height="941"
        />
        <span class="game-card__forest-light"></span>
        <span class="game-card__tree game-card__tree--one"></span>
        <span class="game-card__tree game-card__tree--two"></span>
        <span class="game-card__tree game-card__tree--three"></span>
        <span class="game-card__forest-path"></span>
        <span class="game-card__firefly game-card__firefly--one"></span>
        <span class="game-card__firefly game-card__firefly--two"></span>
        <span class="game-card__firefly game-card__firefly--three"></span>
      </>
    )}

    <span class="game-card__icon">{icon}</span>
  </span>

  <span class="game-card__content">
    <span class="game-card__topline">
      {meta && <span class="game-card__meta">{meta}</span>}
      {status && <span class="game-card__status">{status}</span>}
    </span>
    <h3>{title}</h3>
    <span class="game-card__description">{description}</span>
    <span class="game-card__action">
      <span data-game-cta>{cta}</span>
      {href && <span class="game-card__arrow" aria-hidden="true">→</span>}
    </span>
  </span>
</Tag>

<style>
  .game-card {
    display: grid;
    position: relative;
    grid-template-rows: 190px 1fr;
    min-height: 408px;
    overflow: hidden;
    border: 3px solid var(--color-border);
    border-radius: 28px;
    background: #ffffff;
    box-shadow: 0 9px 0 rgba(8, 33, 74, 0.13);
  }

  .game-card__visual {
    display: grid;
    position: relative;
    place-items: center;
    overflow: hidden;
    border-bottom: 3px solid var(--color-border);
    isolation: isolate;
  }

  .game-card__icon {
    display: grid;
    position: relative;
    z-index: 8;
    min-width: 92px;
    min-height: 82px;
    place-items: center;
    padding: 10px 17px;
    border: 3px solid var(--color-border);
    border-radius: 23px;
    background: #ffffff;
    box-shadow: 0 8px 0 rgba(8, 33, 74, 0.23);
    color: var(--color-text);
    font-size: clamp(2.2rem, 4vw, 3.25rem);
    font-weight: 1000;
    letter-spacing: -0.04em;
    line-height: 1;
    transform: rotate(-4deg);
    transition: transform 200ms ease;
  }

  .game-card--letters .game-card__visual {
    background:
      radial-gradient(circle at 82% 14%, rgba(255, 224, 110, 0.22), transparent 7rem),
      linear-gradient(160deg, #141657, #2e4197 54%, #6a53b6);
  }

  .game-card__constellation {
    position: absolute;
    z-index: 3;
    inset: 16px 16px auto auto;
    width: 72%;
    overflow: visible;
    animation: card-constellation-drift 3.8s ease-in-out infinite alternate;
  }

  .game-card__constellation path {
    fill: none;
    stroke: rgba(255, 231, 119, 0.72);
    stroke-dasharray: 4 7;
    stroke-linecap: round;
    stroke-width: 3;
    animation: card-constellation-route 5s linear infinite;
  }

  .game-card__constellation circle {
    fill: #ffe977;
    filter: drop-shadow(0 0 5px #ffda4e);
    animation: card-star-twinkle 2s ease-in-out infinite alternate;
  }

  .game-card__planet {
    position: absolute;
    z-index: 2;
    bottom: 12px;
    left: 18px;
    width: 116px;
    height: 88px;
  }

  .game-card__planet-body {
    position: absolute;
    z-index: 2;
    top: 0;
    left: 14px;
    width: 88px;
    height: 88px;
    border-radius: 50%;
    background: linear-gradient(135deg, #53c4db, #4555b9 58%, #7d4da2);
    box-shadow:
      inset -18px -12px 0 rgba(12, 25, 91, 0.22),
      0 0 28px rgba(89, 205, 225, 0.24);
  }

  .game-card__planet-ring {
    position: absolute;
    z-index: 1;
    top: 30px;
    left: 0;
    width: 116px;
    height: 31px;
    border: 6px solid rgba(175, 231, 239, 0.72);
    border-radius: 50%;
    transform: rotate(-12deg);
  }

  .game-card__planet-ring--front {
    z-index: 3;
    clip-path: inset(50% 0 0);
  }

  .game-card__shooting-star {
    --shooting-star-angle: 15deg;
    position: absolute;
    z-index: 4;
    top: 20px;
    left: -90px;
    width: 86px;
    height: 4px;
    border-radius: 999px;
    background: linear-gradient(90deg, transparent, #fff4ae);
    box-shadow: 0 0 8px rgba(255, 232, 129, 0.62);
    animation: card-shooting-star 5.4s ease-in-out infinite;
  }

  .game-card__shooting-star::after {
    position: absolute;
    top: 50%;
    right: -2px;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: #fff9cf;
    box-shadow: 0 0 10px 3px rgba(255, 232, 129, 0.6);
    content: "";
    transform: translateY(-50%);
  }

  .game-card--bateau .game-card__visual {
    background: linear-gradient(180deg, #9a73dc 0 42%, #33b6df 42.5%, #0763ad 100%);
  }

  .game-card__sun {
    position: absolute;
    z-index: 1;
    top: 18px;
    right: 24px;
    width: 60px;
    height: 60px;
    border-radius: 50%;
    background: #ffe071;
    box-shadow: 0 0 28px rgba(255, 220, 90, 0.38);
  }

  .game-card__ocean {
    position: absolute;
    z-index: 2;
    right: -16%;
    left: -16%;
    height: 100px;
    border-radius: 49%;
    background: rgba(5, 78, 161, 0.48);
  }

  .game-card__ocean--back {
    top: 45%;
    animation: card-wave 6s ease-in-out infinite alternate;
  }

  .game-card__ocean--front {
    z-index: 5;
    top: 67%;
    background: rgba(4, 59, 139, 0.58);
    animation: card-wave 7.2s -2s ease-in-out infinite alternate-reverse;
  }

  .game-card__island {
    position: absolute;
    z-index: 6;
    right: -110px;
    bottom: 18px;
    height: auto;
    filter: drop-shadow(0 8px 0 rgba(8, 33, 74, 0.2));
    will-change: transform;
  }

  .game-card__island--far {
    z-index: 6;
    bottom: 48px;
    width: 44px;
    opacity: 0.74;
    animation: card-island-pass 13s -8s linear infinite;
  }

  .game-card__island--near {
    bottom: 25px;
    width: 62px;
    animation: card-island-pass 9s -2.5s linear infinite;
  }

  .game-card__boat {
    position: absolute;
    z-index: 7;
    bottom: 22px;
    left: 60%;
    width: 76px;
    height: auto;
    margin-left: -38px;
    filter: drop-shadow(0 7px 0 rgba(8, 33, 74, 0.2));
    animation: card-boat-bob 2.3s ease-in-out infinite alternate;
  }

  .game-card__wind {
    position: absolute;
    z-index: 7;
    right: -70px;
    width: 54px;
    height: 3px;
    border-radius: 999px;
    background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.82));
    opacity: 0;
    filter: drop-shadow(0 0 3px rgba(255, 255, 255, 0.5));
    animation: card-wind-pass 3.2s linear infinite;
  }

  .game-card__wind::after {
    position: absolute;
    top: 8px;
    right: 12px;
    width: 32px;
    height: 2px;
    border-radius: inherit;
    background: inherit;
    content: "";
  }

  .game-card__wind--one {
    top: 35%;
    animation-delay: -0.4s;
  }

  .game-card__wind--two {
    top: 51%;
    width: 42px;
    animation-delay: -1.6s;
  }

  .game-card__wind--three {
    top: 65%;
    width: 62px;
    animation-delay: -2.5s;
  }

  .game-card--bateau .game-card__icon {
    transform: translate(-20px, -7px) rotate(4deg);
  }

  .game-card--forest .game-card__visual {
    background:
      radial-gradient(circle at 74% 21%, rgba(255, 232, 125, 0.46), transparent 5rem),
      linear-gradient(155deg, #234e50, #39784e 58%, #82ae54);
  }

  .game-card__jungle-backdrop {
    position: absolute;
    z-index: 0;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }

  .game-card__forest-light {
    position: absolute;
    top: -35px;
    right: 15%;
    width: 90px;
    height: 230px;
    background: linear-gradient(180deg, rgba(255, 241, 156, 0.46), transparent);
    clip-path: polygon(35% 0, 65% 0, 100% 100%, 0 100%);
    transform: rotate(9deg);
  }

  .game-card__tree {
    position: absolute;
    z-index: 3;
    bottom: -30px;
    width: 46px;
    height: 152px;
    border-radius: 48% 48% 12px 12px;
    background: #173f37;
    box-shadow: inset -10px 0 0 rgba(8, 33, 45, 0.18);
  }

  .game-card__tree::before,
  .game-card__tree::after {
    position: absolute;
    border-radius: 50%;
    background: #2e7850;
    content: "";
  }

  .game-card__tree::before {
    top: -36px;
    left: -31px;
    width: 106px;
    height: 90px;
  }

  .game-card__tree::after {
    top: -5px;
    left: -46px;
    width: 138px;
    height: 74px;
  }

  .game-card__tree--one {
    left: 8px;
  }

  .game-card__tree--two {
    right: 9px;
    height: 176px;
    transform: scale(1.1);
  }

  .game-card__tree--three {
    z-index: 1;
    right: 36%;
    height: 128px;
    opacity: 0.58;
    transform: scale(0.76);
  }

  .game-card__forest-path {
    position: absolute;
    z-index: 2;
    right: 28%;
    bottom: -42px;
    width: 115px;
    height: 160px;
    border-radius: 50%;
    background: #d5b56c;
    clip-path: polygon(42% 0, 61% 0, 91% 100%, 5% 100%);
    transform: rotate(-7deg);
  }

  .game-card__firefly {
    position: absolute;
    z-index: 5;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: #fff48a;
    box-shadow: 0 0 12px 5px rgba(255, 237, 106, 0.36);
    animation: card-firefly 2.8s ease-in-out infinite alternate;
  }

  .game-card__firefly--one {
    top: 36px;
    left: 38%;
  }

  .game-card__firefly--two {
    top: 82px;
    right: 26%;
    animation-delay: -1.1s;
  }

  .game-card__firefly--three {
    bottom: 30px;
    left: 26%;
    animation-delay: -2s;
  }

  .game-card--forest .game-card__icon {
    background: #fff6d7;
    transform: rotate(3deg);
  }

  .game-card__content {
    display: flex;
    min-width: 0;
    flex-direction: column;
    align-items: flex-start;
    gap: 9px;
    padding: 20px;
  }

  .game-card__topline {
    display: flex;
    width: 100%;
    min-height: 29px;
    flex-wrap: wrap;
    align-items: center;
    gap: 8px;
  }

  .game-card__meta,
  .game-card__status {
    display: inline-flex;
    align-items: center;
    border-radius: 999px;
    font-size: 0.76rem;
    font-weight: 950;
    letter-spacing: 0.035em;
    line-height: 1;
    text-transform: uppercase;
  }

  .game-card__meta {
    color: var(--color-blue-dark);
  }

  .game-card__status {
    min-height: 28px;
    margin-left: auto;
    padding-inline: 10px;
    background: #fff0b0;
    color: var(--color-text);
  }

  .game-card h3 {
    margin: 0;
    font-size: clamp(1.55rem, 2.5vw, 2rem);
    letter-spacing: -0.025em;
    line-height: 1.05;
  }

  .game-card__description {
    color: var(--color-muted);
    font-weight: 750;
    line-height: 1.4;
  }

  .game-card__action {
    display: inline-flex;
    min-height: 44px;
    align-items: center;
    gap: 8px;
    margin-top: auto;
    padding: 8px 13px;
    border: 2px solid var(--color-border);
    border-radius: 14px;
    background: var(--color-gold);
    box-shadow: 0 4px 0 rgba(8, 33, 74, 0.14);
    color: var(--color-text);
    font-weight: 1000;
  }

  .game-card--letters .game-card__action {
    background: #d8cdff;
  }

  .game-card__arrow {
    font-size: 1.25rem;
    transition: transform 160ms ease;
  }

  .game-card--interactive {
    transition:
      box-shadow 160ms ease,
      transform 160ms ease;
  }

  .game-card--interactive:hover {
    box-shadow: 0 13px 0 rgba(8, 33, 74, 0.16);
    transform: translateY(-4px);
  }

  .game-card--interactive:hover .game-card__icon {
    transform: translateY(-4px) rotate(2deg) scale(1.04);
  }

  .game-card--interactive.game-card--bateau:hover .game-card__icon {
    transform: translate(-20px, -11px) rotate(2deg) scale(1.04);
  }

  .game-card--interactive:hover .game-card__arrow {
    transform: translateX(4px);
  }

  .game-card--interactive:active {
    box-shadow: 0 4px 0 rgba(8, 33, 74, 0.14);
    transform: translateY(5px);
  }

  .game-card--upcoming {
    border-color: rgba(8, 33, 74, 0.58);
    box-shadow: 0 6px 0 rgba(8, 33, 74, 0.08);
  }

  .game-card--upcoming .game-card__action {
    border-color: rgba(8, 33, 74, 0.25);
    background: #eee9da;
    box-shadow: none;
    color: var(--color-muted);
  }

  @keyframes card-star-twinkle {
    to {
      filter: drop-shadow(0 0 9px #ffdc52);
      opacity: 0.68;
    }
  }

  @keyframes card-constellation-drift {
    to {
      transform: translate(5px, 3px) rotate(1deg);
    }
  }

  @keyframes card-constellation-route {
    to {
      stroke-dashoffset: -22;
    }
  }

  @keyframes card-shooting-star {
    0%,
    68% {
      opacity: 0;
      transform: translate(0, 0) rotate(var(--shooting-star-angle));
    }

    76% {
      opacity: 1;
      transform: translate(50px, 14px) rotate(var(--shooting-star-angle));
    }

    100% {
      opacity: 0;
      transform: translate(420px, 112px) rotate(var(--shooting-star-angle));
    }
  }

  @keyframes card-wave {
    to {
      transform: translateX(24px) rotate(2deg);
    }
  }

  @keyframes card-boat-bob {
    to {
      transform: translateY(7px) rotate(1deg);
    }
  }

  @keyframes card-island-pass {
    to {
      transform: translateX(-520px);
    }
  }

  @keyframes card-wind-pass {
    0% {
      opacity: 0;
      transform: translateX(0);
    }

    16%,
    72% {
      opacity: 0.72;
    }

    100% {
      opacity: 0;
      transform: translateX(-450px);
    }
  }

  @keyframes card-firefly {
    to {
      opacity: 0.42;
      transform: translate(8px, -7px) scale(0.75);
    }
  }

  @media (max-width: 860px) {
    .game-card {
      grid-template-columns: 180px 1fr;
      grid-template-rows: 1fr;
      min-height: 220px;
    }

    .game-card__visual {
      border-right: 3px solid var(--color-border);
      border-bottom: 0;
    }

    .game-card__icon {
      min-width: 72px;
      min-height: 66px;
      padding: 8px 12px;
      border-radius: 19px;
      font-size: 2.1rem;
    }
  }

  @media (max-width: 520px) {
    .game-card {
      grid-template-columns: 116px 1fr;
      min-height: 210px;
      border-radius: 22px;
    }

    .game-card__content {
      gap: 7px;
      padding: 15px 13px;
    }

    .game-card__icon {
      min-width: 58px;
      min-height: 54px;
      padding: 6px 8px;
      border-width: 2px;
      border-radius: 16px;
      font-size: 1.65rem;
    }

    .game-card__planet {
      bottom: 18px;
      left: 8px;
      width: 86px;
      height: 70px;
    }

    .game-card__planet-body {
      left: 8px;
      width: 70px;
      height: 70px;
    }

    .game-card__planet-ring {
      top: 24px;
      left: 0;
      width: 86px;
      height: 25px;
      border-width: 5px;
    }

    .game-card__island--far {
      width: 36px;
    }

    .game-card__island--near {
      width: 48px;
    }

    .game-card__boat {
      bottom: 25px;
      width: 58px;
      margin-left: -29px;
    }

    .game-card__topline {
      min-height: 22px;
    }

    .game-card__meta,
    .game-card__status {
      font-size: 0.63rem;
    }

    .game-card__status {
      min-height: 23px;
      padding-inline: 7px;
    }

    .game-card h3 {
      font-size: 1.25rem;
    }

    .game-card__description {
      font-size: 0.86rem;
      line-height: 1.3;
    }

    .game-card__action {
      min-height: 38px;
      padding: 6px 9px;
      font-size: 0.78rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .game-card *,
    .game-card *::before,
    .game-card *::after {
      animation: none !important;
      transition: none !important;
    }

    .game-card--interactive:hover,
    .game-card--interactive:active {
      transform: none;
    }

    .game-card__island--far,
    .game-card__wind {
      display: none;
    }

    .game-card__island--near {
      right: -18px;
      transform: none;
    }
  }
</style>
