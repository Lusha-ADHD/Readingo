{
  "dialogue": {
    "intro": [
      {
        "id": "intro-01",
        "text": "Aide-moi à parcourir l'océan et à trouver le plus de trésors possibles.",
        "audio": "/assets/audio/fr/dialogue/intro-01.mp3"
      },
      {
        "id": "intro-02",
        "text": "Associe les bonnes syllabes à chaque mot pour que le vent pousse notre bateau !",
        "audio": "/assets/audio/fr/dialogue/intro-02.mp3"
      },
      {
        "id": "intro-03",
        "text": "Je compte sur toi !",
        "audio": "/assets/audio/fr/dialogue/intro-03.mp3"
      }
    ],
    "lettersIntro": [
      {
        "id": "letters-intro-01",
        "text": "Oh non ! Les étoiles qui me montrent le chemin se sont éteintes. Sans elles, je ne peux plus guider mon navire dans la nuit !",
        "audio": "/assets/audio/fr/dialogue/letters-intro-01.mp3"
      },
      {
        "id": "letters-intro-02",
        "text": "Aide-moi à les rallumer ! Pour chaque étoile, tu devras retrouver la lettre qui lui est associée.",
        "audio": "/assets/audio/fr/dialogue/letters-intro-02.mp3"
      },
      {
        "id": "letters-intro-03",
        "text": "Chaque bonne réponse fera briller une étoile et nous montrera la route. En avant pour notre grand voyage !",
        "audio": "/assets/audio/fr/dialogue/letters-intro-03.mp3"
      }
    ],
    "homeOnboarding": [
      {
        "id": "home-welcome",
        "text": "Bonjour moussaillon ! Je m'appelle Pana et je suis la capitaine de ce bateau. Partons ensemble à l'aventure sur ce vaste océan pour jouer avec les mots !",
        "audio": "/assets/audio/fr/dialogue/home-welcome.mp3"
      },
      {
        "id": "home-age",
        "text": "Pour commencer, quel âge as-tu ?",
        "audio": "/assets/audio/fr/dialogue/home-age.mp3"
      },
      {
        "id": "home-skill",
        "text": "Dis-moi maintenant où tu en es avec les lettres et les syllabes.",
        "audio": "/assets/audio/fr/dialogue/home-skill.mp3"
      },
      {
        "id": "home-result-letters",
        "text": "Je te conseille l'Observatoire des lettres. Tu vas apprendre à reconnaître les lettres et leurs sons.",
        "audio": "/assets/audio/fr/dialogue/home-result-letters.mp3"
      },
      {
        "id": "home-result-bateau",
        "text": "Je te conseille l'Archipel des mots. Tu vas assembler des syllabes pour faire avancer ton bateau.",
        "audio": "/assets/audio/fr/dialogue/home-result-bateau.mp3"
      },
      {
        "id": "home-return",
        "text": "Content de te revoir ! Veux-tu reprendre ton aventure ?",
        "audio": "/assets/audio/fr/dialogue/home-return.mp3"
      }
    ],
    "homeAnswers": [
      {
        "id": "home-answer-age-5",
        "text": "5 ans",
        "audio": "/assets/audio/fr/dialogue/home-answer-age-5.mp3"
      },
