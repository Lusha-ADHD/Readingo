# Auto detect text files and perform LF normalization
* text=auto

# Source files
*.astro text eol=lf
*.css text eol=lf
*.html text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.json text eol=lf
*.md text eol=lf
*.mjs text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.yml text eol=lf
*.yaml text eol=lf

# Binary assets
*.avif binary
*.gif binary
*.ico binary
*.jpg binary
*.jpeg binary
*.mp3 binary
*.ogg binary
*.opus binary
*.png binary
*.webm binary
*.webp binary
*.woff binary
*.woff2 binary
